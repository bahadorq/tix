rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if ID is clean (alphanumeric and hyphens, up to 100 chars)
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() < 100 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper to validate Ticket object structure
    function isValidTicket(data) {
      return data.keys().hasAll(['id', 'name', 'status', 'createdAt'])
        && data.keys().size() <= 8
        && data.id is string
        && data.name is string && data.name.size() > 0 && data.name.size() < 200
        && data.status in ['valid', 'checked-in', 'cancelled']
        && data.createdAt is string
        && (!data.keys().hasAny(['checkedInAt']) || data.checkedInAt is string)
        && (!data.keys().hasAny(['notes']) || data.notes is string)
        && (!data.keys().hasAny(['eventName']) || data.eventName is string);
    }

    match /tickets/{ticketId} {
      allow read: if true;
      allow create: if isValidId(ticketId) && isValidTicket(request.resource.data);
      allow update: if isValidId(ticketId) && isValidTicket(request.resource.data);
      allow delete: if isValidId(ticketId);
    }
  }
}
